# Full configuration for the continuous bridge service
# Copy to .env and fill in your values: cp .env.bridge.example .env

# ── Arize AX (required) ──────────────────────────────────────────────────
BRIDGE_ARIZE_SPACE_ID=your-space-id
BRIDGE_ARIZE_API_KEY=your-api-key
BRIDGE_ARIZE_PROJECT_NAME=copilot-studio

# ── Azure Application Insights (required for bridge) ─────────────────────
# Full resource ID — find in Azure Portal → App Insights → Properties → Resource ID
BRIDGE_APPINSIGHTS_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/microsoft.insights/components/<name>

# ── Polling ───────────────────────────────────────────────────────────────
BRIDGE_POLL_INTERVAL_MINUTES=5        # How often to poll (minutes)
BRIDGE_INITIAL_LOOKBACK_HOURS=24      # How far back on first run (hours)

# ── Filtering ─────────────────────────────────────────────────────────────
BRIDGE_EXCLUDE_DESIGN_MODE=true       # Filter out test canvas traffic

# ── State ─────────────────────────────────────────────────────────────────
BRIDGE_CURSOR_PATH=.bridge_cursor.json

# ── Logging ───────────────────────────────────────────────────────────────
BRIDGE_LOG_FORMAT=text                # "text" or "json" (structured)

# ── Resilience ────────────────────────────────────────────────────────────
BRIDGE_MAX_CONSECUTIVE_FAILURES=5     # Escalate to ERROR log level after N failures
BRIDGE_BACKOFF_BASE_SECONDS=60        # Exponential backoff base (seconds)
BRIDGE_BACKOFF_MAX_SECONDS=900        # Backoff cap (15 minutes)

# ── Event buffer ──────────────────────────────────────────────────────────
BRIDGE_BUFFER_GRACE_SECONDS=0         # 0 = disabled; set >0 to merge cross-cycle events

# ── Health check ──────────────────────────────────────────────────────────
BRIDGE_HEALTH_CHECK_ENABLED=true      # GET /health and GET /ready endpoints
BRIDGE_HEALTH_CHECK_PORT=8080
