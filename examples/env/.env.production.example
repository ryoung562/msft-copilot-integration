# Production Configuration for Copilot Studio → Arize AX Bridge
# Copy this file to ../../copilot-insights-bridge/.env and customize with your values

# ============================================================================
# Azure Application Insights Configuration
# ============================================================================

# Full resource ID for your Application Insights instance
# Format: /subscriptions/{subscription-id}/resourceGroups/{resource-group}/providers/microsoft.insights/components/{app-insights-name}
# Find this in Azure Portal → Application Insights → Properties → Resource ID
BRIDGE_APPINSIGHTS_RESOURCE_ID=/subscriptions/YOUR-SUBSCRIPTION-ID/resourceGroups/YOUR-RESOURCE-GROUP/providers/microsoft.insights/components/YOUR-APP-INSIGHTS

# ============================================================================
# Arize AX Configuration
# ============================================================================

# Your Arize space ID (from Arize dashboard)
BRIDGE_ARIZE_SPACE_ID=your-space-id-here

# Your Arize API key (keep this secret! Use Azure Key Vault in production)
BRIDGE_ARIZE_API_KEY=your-api-key-here

# Project name in Arize
BRIDGE_ARIZE_PROJECT_NAME=copilot-studio

# Arize OTLP endpoint (typically no need to change)
# BRIDGE_ARIZE_ENDPOINT=otlp.arize.com:443

# ============================================================================
# Polling Configuration (Production Settings)
# ============================================================================

# How often to poll App Insights (in minutes)
# Production: 5 minutes balances freshness with API costs
BRIDGE_POLL_INTERVAL_MINUTES=5

# How far back to look on first run (in hours)
# Production: 168 hours (7 days) ensures no data loss on initial deployment
BRIDGE_INITIAL_LOOKBACK_HOURS=168

# Buffer time to account for App Insights ingestion lag (in minutes)
# Production: 2-5 minutes recommended to handle ingestion delays
BRIDGE_INGESTION_LAG_BUFFER_MINUTES=2

# ============================================================================
# Filtering Configuration (Production Settings)
# ============================================================================

# Exclude events from design mode / bot test chat
# Production: true to only export real user conversations
BRIDGE_EXCLUDE_DESIGN_MODE=true

# ============================================================================
# Advanced Configuration
# ============================================================================

# Batch size for querying App Insights
# Default: 10000 events per query
# BRIDGE_BATCH_SIZE=10000

# Azure credential method
# Production: Use managed identity if running in Azure (App Service, Container Apps)
# Options: "managed_identity" (recommended for Azure), "cli" (local dev), "environment"
# BRIDGE_AZURE_CREDENTIAL=managed_identity

# Log level
# Production: INFO for standard logging, WARNING for minimal logs
# BRIDGE_LOG_LEVEL=INFO

# ============================================================================
# Production Deployment Checklist
# ============================================================================

# ✅ Security
# - Store BRIDGE_ARIZE_API_KEY in Azure Key Vault or environment secrets
# - Use managed identity for Azure authentication (no credentials in code)
# - Ensure .env file is not committed to git
# - Restrict network access to App Insights and Arize endpoints only

# ✅ Reliability
# - Deploy with at least 2 instances for high availability
# - **IMPORTANT**: Replace file-based cursor with Redis or Azure Blob Storage
#   (file-based cursor not safe for multi-instance deployments)
# - Configure health checks (future: implement /health endpoint)
# - Set up alerts for failed exports or stale cursor

# ✅ Monitoring
# - Enable Application Insights for the bridge itself
# - Configure log aggregation (Azure Log Analytics)
# - Set up dashboards for:
#   - Events processed per hour
#   - Export success rate
#   - Query latency
#   - Cursor lag (time behind real-time)

# ✅ Cost Optimization
# - Monitor App Insights API costs (queries per hour)
# - Consider caching query results if polling frequently
# - Adjust BRIDGE_POLL_INTERVAL_MINUTES based on freshness requirements

# ✅ Testing
# - Test deployment in staging environment first
# - Verify cursor state persists across restarts
# - Confirm no duplicate events in Arize
# - Validate all metadata fields appear in Arize UI

# ============================================================================
# Multi-Instance Deployment Warning
# ============================================================================

# ⚠️ WARNING: File-based cursor is NOT SAFE for multiple instances!
#
# If running multiple instances (for HA), you MUST implement shared cursor storage:
# - Option 1: Azure Blob Storage with lease-based locking
# - Option 2: Redis with atomic operations
# - Option 3: Azure SQL Database with transactions
#
# Without shared cursor:
# - Multiple instances will process same events
# - Duplicate traces in Arize
# - Race conditions on cursor updates
#
# See docs/planning/ for production deployment architecture.
