# Development Configuration for Copilot Studio → Arize AX Bridge
# Copy this file to ../../copilot-insights-bridge/.env and customize with your values

# ============================================================================
# Azure Application Insights Configuration
# ============================================================================

# Full resource ID for your Application Insights instance
# Format: /subscriptions/{subscription-id}/resourceGroups/{resource-group}/providers/microsoft.insights/components/{app-insights-name}
# Find this in Azure Portal → Application Insights → Properties → Resource ID
BRIDGE_APPINSIGHTS_RESOURCE_ID=/subscriptions/YOUR-SUBSCRIPTION-ID/resourceGroups/YOUR-RESOURCE-GROUP/providers/microsoft.insights/components/YOUR-APP-INSIGHTS

# ============================================================================
# Arize AX Configuration
# ============================================================================

# Your Arize space ID (from Arize dashboard)
BRIDGE_ARIZE_SPACE_ID=your-space-id-here

# Your Arize API key (keep this secret!)
BRIDGE_ARIZE_API_KEY=your-api-key-here

# Project name in Arize (will be created if it doesn't exist)
BRIDGE_ARIZE_PROJECT_NAME=copilot-studio-dev

# Arize OTLP endpoint (typically no need to change)
# BRIDGE_ARIZE_ENDPOINT=otlp.arize.com:443

# ============================================================================
# Polling Configuration (Development Settings)
# ============================================================================

# How often to poll App Insights (in minutes)
# Development: 1 minute for faster feedback
# Production: 5+ minutes to reduce API calls
BRIDGE_POLL_INTERVAL_MINUTES=1

# How far back to look on first run (in hours)
# Development: 24 hours (1 day) to get recent conversations
# Production: 168 hours (7 days) or more
BRIDGE_INITIAL_LOOKBACK_HOURS=24

# Buffer time to account for App Insights ingestion lag (in minutes)
# Development: 1 minute (minimal lag)
# Production: 2-5 minutes (safer for production)
BRIDGE_INGESTION_LAG_BUFFER_MINUTES=1

# ============================================================================
# Filtering Configuration (Development Settings)
# ============================================================================

# Exclude events from design mode / bot test chat
# Development: false to see all events (including test conversations)
# Production: true to only export real user conversations
BRIDGE_EXCLUDE_DESIGN_MODE=false

# ============================================================================
# Advanced Configuration (Optional)
# ============================================================================

# Batch size for querying App Insights
# Default: 10000 events per query
# Increase if you have high-volume conversations
# BRIDGE_BATCH_SIZE=10000

# Azure credential method
# Options: "cli" (default, uses az CLI), "managed_identity", "environment"
# BRIDGE_AZURE_CREDENTIAL=cli

# Log level
# Options: DEBUG, INFO, WARNING, ERROR
# Development: DEBUG for verbose logging
# Production: INFO or WARNING
# BRIDGE_LOG_LEVEL=DEBUG

# ============================================================================
# Development Tips
# ============================================================================

# 1. Run once to test: python -m src.main
# 2. Check cursor state: cat ../data/state/.bridge_cursor.json
# 3. Reset cursor to reprocess: rm ../data/state/.bridge_cursor.json
# 4. View logs: (logs are printed to stdout)
# 5. Test with sample data: python scripts/process_partner_data.py ../examples/data/sample-conversation.json --stats
